{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [
    "bin/cli.js",
    "eslint.config.js"
  ],
  "options": {
    "typeAware": true,
    "reportUnusedDisableDirectives": "deny"
  },
  "env": {
    "node": true
  },
  "plugins": [
    "eslint",
    "import",
    "jsdoc",
    "node",
    "oxc",
    "promise",
    "typescript",
    "unicorn"
  ],
  "categories": {
    // The "restriction" category cannot be enabled by default like the others,
    // as some rules are for example to restrict syntaxes for very old browser compatibility,
    // so we need to manually choose the relevant restrictions for the project.
    // The "nursery" category are rules in beta, so also not enabled by default
    // (but once a rule is moved to an enabled category, it can be removed)
    "correctness": "deny",
    "pedantic": "deny",
    "perf": "deny",
    "suspicious": "deny",
    "style": "deny"
  },
  "rules": {
    // Exceptionnally disable some rules aimed to enforce small functions and the single responsibility principle,
    // because it is not relevant for this project and it would require a refactor in classes
    "max-depth": "allow", // in "pedantic"
    "max-lines-per-function": "allow", // in "pedantic"
    "max-params": "allow", // in "style"
    "max-statements": "allow", // in "style"
    // Node project specific rules
    "import/extensions": "deny", // in "restriction"
    "import/no-nodejs-modules": "allow", // in "style", this is a Node project
    "node/no-new-require": "deny", // in "restriction"
    "node/no-process-env": "deny", // in "restriction"
    "unicorn/prefer-node-protocol": "deny", // in "restriction"
    // "restriction" to ESM and prevent CommonJS
    "import/no-commonjs": "deny",
    "import/unambiguous": "deny",
    "typescript/no-require-imports": "deny",
    "unicorn/prefer-module": "deny",
    // Enforce named exports and prevent default exports
    "import/prefer-default-export": "allow", // in "style"
    "import/no-default-export": "deny", // in "restriction"
    "import/no-named-export": "allow", // in "style"
    // "restriction" to prevent imports bad practices which can lead to build and performance issues
    "import/export": "deny", // in "nursery"
    "import/named": "deny", // in "nursery"
    "import/no-cycle": "deny",
    "oxc/no-barrel-file": "deny",
    "typescript/consistent-type-imports": [ // in "style"
      "deny",
      {
        "fixStyle": "inline-type-imports"
      }
    ],
    "typescript/no-import-type-side-effects": "deny", // important when using TypeScript "isolatedModules" and "verbatimModuleSyntax" to prevent empty build files
    // Disable rules already managed by TypeScript directly
    "init-declarations": "allow", // in "style"
    "jsdoc/require-param-type": "allow", // in "pedantic"
    "jsdoc/require-returns-type": "allow", // in "pedantic"
    // Disable "style" formatting rules
    "sort-imports": "allow", // already managed by TypeScript and VS Code
    "sort-keys": "allow", // a logical order is often better
    "import/consistent-type-specifier-style": "allow", // managed by TypeScript and VS Code
    // Disable or loosen some crazy "style" defaults
    "capitalized-comments": "allow",
    "func-style": [
      "deny",
      "declaration" // the default is "expression", which is a bad practice, a function is a function, not a variable
    ],
    "id-length": [
      "deny",
      {
        "checkGeneric": true,
        "exceptions": [
          "a", // used for array methods like .toSorted()
          "b", // used for array methods like .toSorted()
          "_", // used in TypeScript for unused params,
          "T" // used in TypeScript when only one generic
        ]
      }
    ],
    "max-dependencies": "allow", // in "pedantic"
    "no-magic-numbers": [
      "deny",
      {
        "ignoreReadonlyClassProperties": true,
        "ignore": [
          -1, // often used for comparisons
          0, // often used to check the length of an array or access the first element of a list
          1 // often used to increment or decrement
        ]
      }
    ],
    "no-ternary": "allow",
    "prefer-destructuring": "allow",
    "import/group-exports": "allow", // "import/exports-last" already ensures that exports are grouped, no need to complexify
    "unicorn/prefer-string-slice": "allow", // in "pedantic"
    "unicorn/no-useless-undefined": "allow", // in "pedantic", sometimes incorrect, and conflicting with other rules
    "unicorn/numeric-separators-style": "allow",
    "unicorn/prefer-spread": "allow", // `Array.from()` is totally OK and more understandable
    // "restriction" to modern JavaScript
    "no-var": "deny",
    "no-proto": "deny",
    "unicorn/prefer-modern-math-apis": "deny",
    "unicorn/prefer-number-properties": "deny",
    // Enforce strict typing
    "eqeqeq": "deny", // in "pedantic"
    "prefer-arrow-callback": "deny",
    "prefer-template": "deny", // in "style"
    "typescript/explicit-function-return-type": "deny", // in "restriction"
    "typescript/explicit-module-boundary-types": "deny", // in "restriction"
    "typescript/no-explicit-any": "deny", // in "restriction"
    "typescript/no-non-null-assertion": "deny", // in "restriction"
    "typescript/no-unsafe-argument": "deny", // in "pedantic"
    "typescript/no-unsafe-assignment": "deny", // in "pedantic"
    "typescript/no-unsafe-call": "deny", // in "pedantic"
    "typescript/no-unsafe-member-access": "deny", // in "pedantic"
    "typescript/no-unsafe-return": "deny", // in "pedantic"
    "typescript/no-unsafe-type-assertion": "deny", // in "suspicious"
    "typescript/prefer-for-of": "deny", // in "style"
    "typescript/prefer-nullish-coalescing": "deny", // in "pedantic"
    "typescript/prefer-optional-chain": "deny", // in "nursery"
    "typescript/restrict-plus-operands": [ // in "pedantic"
      "deny",
      {
        "allowAny": false,
        "allowBoolean": false,
        "allowNullish": false,
        "allowNumberAndString": false,
        "allowRegExp": false,
      }
    ],
    "typescript/restrict-template-expressions": "deny", // in "correctness" and default
    "typescript/strict-boolean-expressions": [ // in "pedantic"
      "deny",
      {
        "allowNumber": false,
        "allowString": false,
      }
    ],
    "typescript/strict-void-return": "deny", // in "pedantic"
    "typescript/use-unknown-in-catch-callback-variable": "deny", // in "restriction"
    // Enforce immutability
    "no-shadow": "deny", // in "suspicious"
    "prefer-const": "deny", // in "style"
    "prefer-readonly": "deny", // in "style"
    "typescript/prefer-readonly-parameter-types": [ // in "pedantic"
      "deny",
      {
        "allow": [
          {
            "from": "package",
            "name": "ModificationOptions",
            "package": "jsonc-parser"
          },
          {
            "from": "package",
            "name": "CodeBlockWriter",
            "package": "ts-morph"
          },
          {
            "from": "package",
            "name": "ObjectLiteralExpression",
            "package": "ts-morph"
          },
        ]
      }
    ],
    // "restriction" of error prone syntaxes
    "getter-return": "deny", // in "nursery"
    "no-bitwise": "deny",
    "no-plusplus": "deny",
    "no-regex-spaces": "deny",
    "no-sequences": "deny",
    "no-undef": "deny", // in "nursery"
    "no-unreachable": "deny", // in "nursery"
    "no-use-before-define": "deny",
    "no-void": "deny",
    "jsdoc/check-access": "deny",
    "oxc/bad-bitwise-operator": "deny",
    "oxc/no-const-enum": "deny",
    "promise/catch-or-return": "deny",
    "promise/no-return-in-finally": "deny", // in "nursery"
    "promise/spec-only": "deny",
    "typescript/no-dynamic-delete": "deny",
    "typescript/no-empty-object-type": "deny",
    "typescript/no-invalid-void-type": "deny",
    "typescript/no-namespace": "deny",
    "typescript/non-nullable-type-assertion-style": "deny",
    "typescript/prefer-literal-enum-member": "deny",
    "typescript/promise-function-async": "deny",
    "unicorn/no-array-for-each": "deny",
    "unicorn/no-array-reduce": "deny",
    "unicorn/no-abusive-eslint-disable": "deny",
    // "restriction" to good practices
    "class-methods-use-this": "deny",
    "oxc/branches-sharing-code": "deny", // in "nursery"
    // "restriction" to prevent empty or unnecessary elements
    "no-empty": [
      "deny",
      {
        "allowEmptyCatch": true // `catch` is required after a `try`, but there is not always something to do inside
      }
    ],
    "no-empty-function": [
      "deny",
      {
        "allow": [
          "arrowFunctions" // some callbacks are required (like in promises `.catch()`), but there is not always something to do inside
        ],
      },
    ],
    "no-useless-assignment": "deny", // in "nursery"
    "jsdoc/empty-tags": "deny",
    "typescript/no-unnecessary-condition": "deny", // in "nursery"
    "unicorn/no-useless-iterator-to-array": "deny" // in "nursery"
  }
}