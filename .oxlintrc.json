{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": [
    "bin/cli.js",
    "eslint.config.js"
  ],
  "options": {
    "typeAware": true,
    "reportUnusedDisableDirectives": "deny"
  },
  "plugins": [
    "eslint",
    "import",
    "jsdoc",
    "node",
    "oxc",
    "promise",
    "typescript",
    "unicorn"
  ],
  "categories": {
    // The "restriction" category cannot be enabled by default like the others,
    // as some rules are for example to restrict syntaxes for very old browser compatibility,
    // so we need to manually choose the relevant restrictions for the project.
    // The "nursery" category are rules in beta, so also not enabled by default
    // (but once a rule is moved to an enabled category, it can be removed)
    "correctness": "deny",
    "pedantic": "deny",
    "perf": "deny",
    "suspicious": "deny",
    "style": "deny"
  },
  "rules": {
    // Exceptionnally disable some rules aimed to enforce small functions and the single responsibility principle,
    // because it is not relevant for this project and it would require a refactor in classes
    "max-depth": "allow", // in "pedantic"
    "max-lines-per-function": "allow", // in "pedantic"
    "max-params": "allow", // in "style"
    "max-statements": "allow", // in "style"
    // Node project specific rules
    "import/extensions": "deny", // in "restriction"
    "import/no-nodejs-modules": "allow", // in "style", this is a Node project
    "node/no-new-require": "deny", // in "restriction"
    "node/no-process-env": "deny", // in "restriction"
    "unicorn/prefer-node-protocol": "deny", // in "restriction"
    // Enforce ESM and prevent CommonJS
    "import/no-commonjs": "deny", // in "restriction"
    "import/unambiguous": "deny", // in "restriction"
    "typescript/no-require-imports": "deny", // in "restriction"
    "unicorn/prefer-module": "deny", // in "restriction"
    // Enforce named exports and prevent default exports
    "import/prefer-default-export": "allow", // in "style"
    "import/no-default-export": "deny", // in "restriction"
    "import/no-named-export": "allow", // in "style"
    // Prevent imports bad practices which can lead to build and performance issues
    "import/export": "deny", // in "nursery"
    "import/group-exports": "allow", // in "style", "import/exports-last" already ensures that exports are grouped, no need to complexify
    "import/named": "deny", // in "nursery"
    "import/no-cycle": "deny", // in "restriction"
    "oxc/no-barrel-file": "deny", // in "restriction"
    "typescript/no-import-type-side-effects": "deny", // in "restriction", important when using TypeScript "isolatedModules" and "verbatimModuleSyntax" to prevent empty build files
    // Disable rules already managed by TypeScript directly
    "init-declarations": "allow", // in "style"
    "jsdoc/require-param-type": "allow", // in "pedantic"
    "jsdoc/require-returns-type": "allow", // in "pedantic"
    // Disable formatting rules
    "sort-imports": "allow", // in "style", already managed by TypeScript and VS Code
    "sort-keys": "allow", //  in "style", and a logical order is often better
    "import/consistent-type-specifier-style": "allow", // in "style", managed by TypeScript and VS Code
    // Disable or loosen some crazy defaults
    "func-style": [ // in "style"
      "deny",
      "declaration" // the default is "expression", which is a bad practice, a function is a function, not a variable
    ],
    "no-magic-numbers": [ // in "style"
      "deny",
      {
        "ignore": [
          0, // often used to check the length of an array or access the first element of a list
          1 // often used to increment or decrement
        ]
      }
    ],
    "no-ternary": "allow", // in "style", perhaps learn some basic programming?
    // Enforce modern JavaScript
    "no-var": "deny",
    "no-proto": "deny", // in "restriction"
    "unicorn/prefer-modern-math-apis": "deny", // in "restriction"
    "unicorn/prefer-number-properties": "deny", // in "restriction"
    // Enforce strict typing
    "eqeqeq": "deny", // in "pedantic"
    "prefer-template": "deny", // in "style"
    "typescript/explicit-function-return-type": "deny", // in "restriction"
    "typescript/explicit-module-boundary-types": "deny", // in "restriction"
    "typescript/no-explicit-any": "deny", // in "restriction"
    "typescript/no-non-null-assertion": "deny", // in "restriction"
    "typescript/no-unsafe-argument": "deny", // in "pedantic"
    "typescript/no-unsafe-assignment": "deny", // in "pedantic"
    "typescript/no-unsafe-call": "deny", // in "pedantic"
    "typescript/no-unsafe-member-access": "deny", // in "pedantic"
    "typescript/no-unsafe-return": "deny", // in "pedantic"
    "typescript/no-unsafe-type-assertion": "deny", // in "suspicious"
    "typescript/prefer-for-of": "deny", // in "style"
    "typescript/prefer-nullish-coalescing": "deny", // in "pedantic"
    "typescript/prefer-optional-chain": "deny", // in "nursery"
    "typescript/restrict-plus-operands": [ // in "pedantic"
      "deny",
      {
        "allowAny": false,
        "allowBoolean": false,
        "allowNullish": false,
        "allowNumberAndString": false,
        "allowRegExp": false,
      }
    ],
    "typescript/restrict-template-expressions": "deny", // in "correctness" and default
    "typescript/strict-boolean-expressions": [ // in "pedantic"
      "deny",
      {
        "allowNumber": false,
        "allowString": false,
      }
    ],
    "typescript/strict-void-return": "deny", // in "nursery"
    "typescript/use-unknown-in-catch-callback-variable": "deny", // in "restriction"
    // Enforce immutability
    "no-shadow": "deny", // in "suspicious"
    "prefer-const": "deny", // in "style"
    "prefer-readonly": "deny", // in "style"
    "typescript/prefer-readonly-parameter-types": [ // in "nursery"
      "deny",
      {
        "allow": [
          {
            "from": "package",
            "name": "ModificationOptions",
            "package": "jsonc-parser"
          },
          {
            "from": "package",
            "name": "CodeBlockWriter",
            "package": "ts-morph"
          },
          {
            "from": "package",
            "name": "ObjectLiteralExpression",
            "package": "ts-morph"
          },
        ]
      }
    ],
    // Prevent error prone syntaxes
    "getter-return": "deny", // in "nursery"
    "no-bitwise": "deny", // in "restriction"
    "no-plusplus": "deny", // in "restriction"
    "no-regex-spaces": "deny", // in "restriction"
    "no-sequences": "deny", // in "restriction"
    "no-undef": "deny", // in "nursery"
    "no-unreachable": "deny", // in "nursery"
    "no-use-before-define": "deny", // in "restriction"
    "no-void": "deny", // in "restriction"
    "jsdoc/check-access": "deny", // in "restriction"
    "oxc/bad-bitwise-operator": "deny", // in "restriction"
    "oxc/no-const-enum": "deny", // in "restriction"
    "promise/catch-or-return": "deny", // in "restriction"
    "promise/no-return-in-finally": "deny", // in "nursery"
    "promise/spec-only": "deny", // in "restriction"
    "typescript/consistent-return": "deny", // in "nursery"
    "typescript/dot-notation": "deny", // in "nursery"
    "typescript/no-dynamic-delete": "deny", // in "restriction"
    "typescript/no-empty-object-type": "deny", // in "restriction"
    "typescript/no-invalid-void-type": "deny", // in "restriction"
    "typescript/no-namespace": "deny", // in "restriction"
    "typescript/non-nullable-type-assertion-style": "deny", // in "restriction"
    "typescript/prefer-literal-enum-member": "deny", // in "restriction"
    "typescript/promise-function-async": "deny", // in "restriction"
    "unicorn/no-array-for-each": "deny", // in "restriction"
    "unicorn/no-array-reduce": "deny", // in "restriction"
    "unicorn/no-abusive-eslint-disable": "deny", // in "restriction"
    // Enforce good practices
    "class-methods-use-this": "deny", // in "restriction"
    "oxc/branches-sharing-code": "deny", // in "nursery"
    // Prevent empty or unnecessary elements
    "no-empty": "deny", // in "restriction"
    "no-empty-function": "deny", // in "restriction"
    "jsdoc/empty-tags": "deny", // in "restriction"
    "typescript/no-unnecessary-condition": "deny", // in "nursery"
    "typescript/no-unnecessary-qualifier": "deny", // in "nursery"
    "typescript/no-unnecessary-type-conversion": "deny", // in "nursery"
    "typescript/no-unnecessary-type-parameters": "deny", // in "nursery"
    "typescript/no-useless-default-assignment": "deny", // in "nursery"
  }
}