{
  "name": "typescript-strictly-typed",
  "version": "3.31.0",
  "description": "Enable configurations for strictly typed TypeScript, ESLint, and optionally Angular.",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/cyrilletuzi"
  },
  "main": "index.js",
  "bin": {
    "typescript-strictly-typed": "bin/cli.js"
  },
  "type": "module",
  "engines": {
    "node": ">=24.10.0",
    "npm": ">=11.6.0"
  },
  "scripts": {
    "build": "rm -rf dist && tsc && cp package.json LICENSE src/README.md dist && mkdir dist/bin && cp bin/cli.js dist/bin/cli.js",
    "lint": "oxlint",
    "test": "echo \"Error: no test specified\" && exit 1",
    "release:major": "VERSION=major npm run release",
    "release:minor": "VERSION=minor npm run release",
    "release:patch": "VERSION=patch npm run release",
    "release": "if test $VERSION; then npm run build && npm version $VERSION && git push; fi",
    "publish-release": "git push origin v$npm_package_version"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cyrilletuzi/typescript-strictly-typed.git"
  },
  "author": "Cyrille Tuzi",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/cyrilletuzi/typescript-strictly-typed/issues"
  },
  "homepage": "https://github.com/cyrilletuzi/typescript-strictly-typed",
  "dependencies": {
    "js-yaml": "^4.1.1",
    "jsonc-parser": "^3.3.1",
    "package-up": "^5.0.0",
    "semver": "^7.8.1",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "~24.10.0",
    "@types/semver": "^7.7.1",
    "better-typescript-lib": "~2.12.0",
    "oxlint": "^1.67.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "~6.0.2"
  }
}
